#!/bin/bash
#
# Pre-push hook for azure-bootstrap
# Runs comprehensive checks before allowing push
#
# This hook runs:
# 1. All pre-commit checks
# 2. Full test suite with verbose output
# 3. Build verification

set -e

echo "🚀 Running pre-push checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get Python executable
if [ -f ".venv/Scripts/python.exe" ]; then
    PYTHON=".venv/Scripts/python.exe"
elif [ -f ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"
else
    echo -e "${RED}❌ Virtual environment not found!${NC}"
    exit 1
fi

FAILED=0

# 1. Run pre-commit checks first
echo -e "${YELLOW}⏳ Running all pre-commit checks...${NC}"
if .githooks/pre-commit; then
    echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
    echo ""
else
    echo -e "${RED}❌ Pre-commit checks failed${NC}"
    FAILED=1
fi

# 2. Run full test suite with verbose output
echo -e "${YELLOW}⏳ Running full test suite (verbose)...${NC}"
if $PYTHON -m pytest test/ -v --cov=azure_bootstrap --cov-report=term-missing --cov-report=html --cov-fail-under=80; then
    echo -e "${GREEN}✅ Full test suite passed${NC}"
    echo ""
else
    echo -e "${RED}❌ Test suite failed${NC}"
    FAILED=1
fi

# 3. Verify package builds
echo -e "${YELLOW}⏳ Verifying package build...${NC}"
if $PYTHON -m build --outdir dist_test 2>&1 | tail -5; then
    echo -e "${GREEN}✅ Package builds successfully${NC}"
    rm -rf dist_test
    echo ""
else
    echo -e "${RED}❌ Package build failed${NC}"
    rm -rf dist_test
    FAILED=1
fi

# Summary
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
    echo -e "${GREEN}🚀 Safe to push${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
else
    echo -e "${RED}❌ Some checks failed - push blocked${NC}"
    echo ""
    echo "To skip these checks (not recommended):"
    echo "  git push --no-verify"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
fi
